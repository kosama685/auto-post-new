# Copy this file to .env and fill your private values.
# Do not commit .env to Git.

APP_NAME="Arabic Herbal Health Blog Dashboard"
APP_ENV="local"
TZ="Asia/Riyadh"

# OpenAI rewriting and optional image generation
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
ENABLE_AI_REWRITE="true"
ENABLE_IMAGE_GENERATION="false"

# Optional NewsAPI discovery
NEWSAPI_KEY="dd7d5179f434482d9f3671450a935520"
NEWSAPI_LANGUAGE="ar"
NEWSAPI_PAGE_SIZE="10"

# Optional Currents API discovery
CURRENTS_API_KEY="6N_x-7lKI6nAucni96RT8SW5gYOu_tmeG5SBDMH_jUiJcBHd"
CURRENTS_API_LANGUAGE="ar"
CURRENTS_API_COUNTRY="6N_x-7lKI6nAucni96RT8SW5gYOu_tmeG5SBDMH_jUiJcBHd"
CURRENTS_API_CATEGORY="health"
GEMINI_API_KEY="AIzaSyDqTPSChhW2e-VSt_Aw4kQNYfUTlJRYenU"
# Blogger target website
TARGET_PLATFORM="blogger"
BLOGGER_BLOG_ID="3028545707053082053"
BLOGGER_POST_AS_DRAFT="true"
GOOGLE_CLIENT_SECRET_FILE="client_secret.json"
GOOGLE_TOKEN_FILE="token.json"

# Optional Cloudinary image hosting for generated images
CLOUDINARY_CLOUD_NAME="Root"
CLOUDINARY_API_KEY="911396936115146"
CLOUDINARY_API_SECRET="qajWQXzTFMhUDdmRV08IsARZCQo"

# Scheduling
POST_INTERVAL_HOURS="4"
MAX_POSTS_PER_RUN="2"
FETCH_LIMIT_PER_SOURCE="10"
REQUEST_DELAY_SECONDS="2"

# SEO / safety
SITE_NAME="مدونة الصحة والأعشاب"
SITE_BASE_URL=""
DEFAULT_AUTHOR="فريق التحرير"
SAUDI_GEO_TARGETING="true"
REQUIRE_REVIEW_BEFORE_PUBLISH="true"
MEDICAL_DISCLAIMER="المعلومات الواردة في هذا المقال عامة ولا تغني عن استشارة الطبيب أو الصيدلي المختص."

# Storage/logging
DATABASE_URL="sqlite:///data/app.db"
LOG_LEVEL="INFO"
